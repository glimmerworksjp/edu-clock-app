{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "edu-clock-app",
  "compatibility_date": "2026-04-19",
  "assets": {
    "directory": "./dist"
  },
  "routes": [
    { "pattern": "app.edu-clock.com", "custom_domain": true }
  ],
  "workers_dev": false,
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
